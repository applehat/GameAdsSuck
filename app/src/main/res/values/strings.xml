    <string name="btn_remove_app">Remove</string>
    <string name="menu_settings">Settings</string>

    <!-- Permission guidance -->
    <string name="restricted_settings_title">Allow Restricted Settings</string>
    <string name="restricted_settings_message">On Android 13+, sideloaded apps need \"Allow restricted settings\" to use accessibility.\n\n1. Open Settings → Apps → GameAdsSuck\n2. Tap the ⋮ menu (top-right)\n3. Select \"Allow restricted settings\"\n4. Return here and enable the Ad Detector\n\nTap OK to open App Settings now.</string>
    <string name="restricted_settings_ok">Open App Settings</string>
    <string name="restricted_settings_cancel">Cancel</string>

